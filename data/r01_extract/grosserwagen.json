      "is_license": false
    },
    {
      "idx": 2,
      "emf": "image3.emf",
      "ext": "emf",
      "quelle": "vektor",
      "png": "data/r01_render/grosserwagen/02_image3.emf.png",
      "tokens": "Gregor zeichnet noch einen Stern ein, der zum Sternbild „Großer Wagen“ gehört. Dieser Stern hat die Koordinaten:7. Stern( -6 | -1 ).Zeichne diesen Stern in das Koordinatensystem ein und verbinde ihn mit dem6. Stern.",
      "deterministic_text": "Gregor zeichnet noch einen Stern ein, der zum Sternbild „Großer Wagen“ gehört.\nDieser Stern hat die Koordinaten:7. Stern( -6 | -1 ).\nZeichne diesen Stern in das Koordinatensystem ein und verbinde ihn mit dem\n6. Stern.",
      "table": null,
      "n_fragments": 21,
      "is_license": false
    },
    {
      "idx": 3,
      "emf": "image4.emf",
      "ext": "emf",
      "quelle": "vektor",
      "png": "data/r01_render/grosserwagen/03_image4.emf.png",
      "tokens": "Verlängert man die gedachte Verbindungslinie zwischen dem 2. und dem 1. Stern des „Großen Wagens“ vom 1. Stern aus um das Fünffache nach oben, findet man den Polarstern.Schreibe die Koordinaten auf, die der Polarstern in Gregors Koordinatensystem hätte.Hinweis: Man kann den Stern nicht mehr in das Koordinatensystem einzeichnen.Polarstern ( |        )",
      "deterministic_text": "Verlängert man die gedachte Verbindungslinie zwischen dem 2. und dem 1. Stern des\n„Großen Wagens“ vom 1. Stern aus um das Fünffache nach oben, findet man den\nPolarstern.\nSchreibe die Koordinaten auf, die der Polarstern in Gregors Koordinatensystem hätte.\nHinweis: Man kann den Stern nicht mehr in das Koordinatensystem einzeichnen.\nPolarstern ( | )",
