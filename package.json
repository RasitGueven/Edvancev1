{
  "name": "edvance",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:mock": "tsx --test src/lib/mocks/sessionMachine.test.ts src/pages/mock/session/components/taskEval.test.ts src/lib/answer/evaluators.test.ts src/components/edvance/tasks/answer/answerState.test.ts",
    "seed:clusters": "tsx --env-file=.env scripts/seed-clusters.ts",
    "seed:taxonomy": "tsx --env-file=.env scripts/seed-taxonomy.ts",
    "mark:diagnostic": "tsx --env-file=.env scripts/mark-diagnostic.ts",
    "seed:screening-items": "tsx --env-file=.env scripts/seed-screening-items.ts",
    "seed:vera8": "tsx --env-file=.env scripts/seed_vera8.ts",
    "seed:test-student": "tsx --env-file=.env scripts/seed-test-student.ts",
    "import:lsa-items": "tsx --env-file=.env scripts/import-lsa-items.ts",
    "import:lambacher": "tsx --env-file=.env scripts/import/lambacher.ts",
    "generate:assets": "tsx --env-file=.env scripts/generate-assets.ts",
    "assets:upload": "tsx --env-file=.env scripts/upload-task-assets.ts",
    "sim:screening": "tsx scripts/screening-sim.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "@types/katex": "^0.16.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "i18next": "^26.2.0",
    "jsxgraph": "^1.12.2",
    "katex": "^0.16.45",
    "lucide-react": "^0.460.0",
    "mafs": "^0.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.10",
    "ws": "^8.20.0"
  }
}
